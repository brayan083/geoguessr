{
  "rules": {
    "rooms": {
      "$code": {
        ".read": "auth != null",
        ".write": "auth != null && (!data.exists() || data.child('players').child(auth.uid).exists())",
        "players": {
          "$playerId": {
            ".write": "auth != null && auth.uid === $playerId"
          }
        },
        "rounds": {
          "$roundId": {
            "guesses": {
              "$playerId": {
                ".write": "auth != null && auth.uid === $playerId && !data.exists()"
              }
            }
          }
        }
      }
    }
  }
}
